  "keyFeatures": [
    "On-demand roadside assistance requests (flat tyre, battery jump, fuel delivery, towing, lockout)",
    "Real-time GPS tracking of incoming mechanic/recovery vehicle",
    "Instant job matching connecting drivers with nearby verified mechanics",
    "In-app chat and calling between driver and mechanic",
    "Transparent upfront pricing with no hidden fees",
    "Multiple payment methods including card, wallet, and pay-on-arrival",
    "Driver and mechanic ratings and reviews system",
    "Mechanic earnings dashboard with weekly payouts",
    "Service area coverage map",
    "24/7 in-app safety and emergency support"
  ],
  "publicApiSurface": [
    "POST /v1/requests — create a new breakdown assistance request",
    "GET /v1/requests/{id} — retrieve request status and mechanic ETA",
    "DELETE /v1/requests/{id} — cancel an active request",
    "GET /v1/mechanics/nearby — list available mechanics near a location",
    "POST /v1/auth/token — obtain an API access token",
    "POST /v1/webhooks — register a webhook endpoint",
    "GET /v1/jobs/{id} — retrieve job details (mechanic-facing)",
    "PATCH /v1/jobs/{id}/status — update job status (mechanic-facing)"
  ]
